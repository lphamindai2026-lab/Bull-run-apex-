# ============================================================
# BULL RUN APEX AI — ENVIRONMENT VARIABLES TEMPLATE
# Founded by Himanshu Bhmniya | bullrunapex@gmail.com
#
# HOW TO USE:
#   1. Copy this file: cp .env.example .env
#   2. Fill in your real values
#   3. Never commit the .env file to Git
#
# For Vercel deployment: add these in the Vercel dashboard
#   Project → Settings → Environment Variables
# ============================================================

# ── Required: Database ───────────────────────────────────────
# Local development:
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/app_db

# Production (example providers):
# Neon:     postgresql://user:pass@ep-xxx.us-east-1.aws.neon.tech/neondb?sslmode=require
# Supabase: postgresql://postgres:pass@db.xxx.supabase.co:5432/postgres
# Railway:  postgresql://postgres:pass@roundhouse.proxy.rlwy.net:xxxxx/railway

# ── Required: Production Site URL ────────────────────────────
# Set to your actual domain AFTER you purchase and configure it.
# Example: https://bullrunapexai.com
# DO NOT use e2b.app preview URLs here.
NEXT_PUBLIC_SITE_URL=https://YOUR_DOMAIN_HERE.com

# ── Required for Google Search Console ───────────────────────
# Instructions:
#   1. Go to https://search.google.com/search-console
#   2. Add Property → your domain
#   3. Choose "HTML tag" verification method
#   4. Copy only the content="..." value (not the whole tag)
#   5. Paste it here
# Example: abc123xyz789abc123
GOOGLE_SITE_VERIFICATION=

# ── Optional: AI Model APIs ───────────────────────────────────
# Without these keys, the AI chat uses the built-in expert system.
# With valid keys, responses come from the real AI models.

# Google Gemini: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# OpenAI: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# ── Optional: Node Environment ────────────────────────────────
NODE_ENV=production
